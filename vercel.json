{
  "rewrites": [
    { "source": "/tutorials/:param*", "destination": "/api/og?section=tutorials&param=:param*" },
    { "source": "/jobs/:param*",      "destination": "/api/og?section=jobs&param=:param*" },
    { "source": "/path/:param*",      "destination": "/api/og?section=path&param=:param*" },
    { "source": "/news",              "destination": "/api/og?section=news" },
    { "source": "/tools",             "destination": "/api/og?section=tools" },
    { "source": "/models",            "destination": "/api/og?section=models" },
    { "source": "/prompts",           "destination": "/api/og?section=prompts" },
    { "source": "/resources",         "destination": "/api/og?section=resources" },
    { "source": "/diagnosis",         "destination": "/api/og?section=diagnosis" },
    { "source": "/video-tool",        "destination": "/api/og?section=video-tool" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, s-maxage=86400"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, max-age=604800"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; img-src 'self' data: https:; connect-src 'self' https:; frame-src https://www.youtube.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/data/(.*).json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=1800, s-maxage=3600"
        },
        {
          "key": "Vercel-CDN-Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    }
  ]
}
