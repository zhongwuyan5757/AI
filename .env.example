# FiveSeven AI - 自动化配置
# 复制此文件为 .env 并填入你的 API keys

# Anthropic Claude API Key (用于AI智能分类、内容摘要、视频学习助手)
# 视频学习助手的 AI 功能（精简/提炼/翻译）需要此 Key
# 如果不设置，数据抓取脚本会使用基于规则的 heuristic 分类
ANTHROPIC_API_KEY=

# GitHub Personal Access Token (可选 - 提高 API 限制)
GITHUB_TOKEN=

# Product Hunt API Token (可选)
PRODUCTHUNT_TOKEN=
